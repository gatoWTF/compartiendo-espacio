{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "turbo run build",
  "devCommand": "turbo run dev",
  "framework": "nextjs",
  "regions": ["scl1"],
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "https://auth-ms-tu-url.vercel.app/api/v1/auth/:path*"
    },
    {
      "source": "/api/mapas/:path*",
      "destination": "https://mapas-ms-tu-url.vercel.app/api/v1/search/:path*"
    },
    {
      "source": "/api/reservas/:path*",
      "destination": "https://reservas-ms-tu-url.vercel.app/api/v1/reserve/:path*"
    }
  ]
}